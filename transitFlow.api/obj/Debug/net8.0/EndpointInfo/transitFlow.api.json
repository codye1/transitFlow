            "type": "string"
          },
          "color": {
            "minLength": 1,
            "type": "string"
          },
          "selectedStops": {
            "minItems": 2,
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
