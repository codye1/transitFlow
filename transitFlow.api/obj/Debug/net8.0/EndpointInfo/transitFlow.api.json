          "model": {
            "type": "string",
            "nullable": true
          },
          "routeId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "capacity": {
            "type": "integer",
            "format": "int32"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdById": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
