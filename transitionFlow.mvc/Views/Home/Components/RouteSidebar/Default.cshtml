@model TransitFlow.mvc.Models.RouteSidebarViewModel
@inject IComponentAssetManager AssetManager

@{
    AssetManager.RegisterStyle("/css/views/Home/components/RouteSidebar/route-sidebar.css");

    AssetManager.RegisterScript("/lib/jquery-validation/dist/jquery.validate.min.js");
    
    AssetManager.RegisterScript("/js/views/Home/components/RouteSidebar/routeSidebarApi.js");
    AssetManager.RegisterScript("/js/views/Home/components/RouteSidebar/routeSidebarValidator.js");
    
    AssetManager.RegisterScript("/js/views/Home/components/RouteSidebar/routeSidebar.js");
}

<aside class="sidebar">
    <div class="sidebar-header">
        <h3 class="sidebar-title">Маршрути</h3>
        <button class="btn-primary" id="open-route-modal-btn">Додати</button>
    </div>

    <div class="route-list">
        @if (!Model.Routes.Any())
        {
            <p>Маршрутів ще немає</p>
        }

        @foreach (var route in Model.Routes)
        {
            <div class="route-item" data-id="@route.Id">
                <div class="route-color-indicator" style="background-color: @(string.IsNullOrEmpty(route.Color) ? "#3b82f6" : route.Color)"></div>

                <div class="route-info">
                    <div class="route-meta">
                        <span class="route-number">№@route.Number</span>
                    </div>
                    <div class="route-name">@route.Name</div>
                    <div class="route-stops-count">@(route.Stops?.Count() ?? 0) зупинок</div>
                </div>
                @if (Model.User != null && (route.CreatedById == Model.User.Id || Model.User.Roles.Contains(AppRole.Admin) || Model.User.Roles.Contains(AppRole.Moderator)))
                {
                    <div class="route-actions">
                        <button class="icon-btn btn-edit-route" title="Редагувати"><img src="~/images/icons/edit.svg" alt="EditIcon" /></button>
                        <button class="icon-btn btn-delete-route" title="Видалити"><img src="~/images/icons/delete.svg" alt="DeleteIcon" /></button>
                    </div>
                }
            </div>
        }
    </div>

    <template id="tpl-add-route">
        <form id="form-add-route" class="modal-form-layout">
            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label">Номер</label>
                    <input type="text" name="number" id="route-number" required placeholder="12А" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Тип</label>
                    <select name="type" id="route-type" class="form-input">
                        <option value="bus">Автобус</option>
                        <option value="tram">Трамвай</option>
                        <option value="trolleybus">Тролейбус</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Назва</label>
                <input type="text" name="name" id="route-name" required placeholder="Вокзал — Аеропорт" class="form-input" />
            </div>

            <div class="form-group">
                <label class="form-label">Колір</label>
                <div class="color-picker-group">
                    @{
                        var presetColors = new[] { "#ef4444", "#3b82f6", "#10b981", "#f59e0b", "#6366f1", "#8b5cf6" };
                        foreach (var color in presetColors)
                        {
                            <button type="button" class="color-dot selected" data-color="@color" style="background-color: @color;"></button>
                        }
                    }
                    <input type="hidden" name="color" id="selected-route-color" value="#ef4444" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Зупинки (у порядку маршруту)</label>
                <div id="selected-stops-list" class="selected-stops-container">
                </div>

                <div class="stops-bucket-selector" id="available-stops-bucket">
    @foreach (var stop in Model.AllStops)
    {
        <button type="button" class="bucket-item-btn" 
                data-stop-id="@stop.Id" 
                data-lat="@stop.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)" 
                data-lon="@stop.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)">
            <img class="icon" src="~/images/icons/add.svg" alt="AddIcon" /> @stop.Name
        </button>
    }
    <div class="bucket-empty-state hidden" id="bucket-empty-msg">Всі зупинки додано</div>
</div>

                <button type="button" id="btn-route-pick-map" class="btn-outline-map" style="margin-top: 10px;">
                    📍 Обрати зупинки на карті
                </button>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-primary" id="js-close-route-modal">
                    <span class="btn-text">Скасувати</span>
                </button>
                <button type="submit" id="btn-submit-route" class="btn-primary">
                    <span class="btn-text">Створити</span>
                    <span class="spinner"></span>
                </button>
            </div>
        </form>
    </template>
</aside>