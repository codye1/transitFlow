@model StopSidebarViewModel
@inject IComponentAssetManager AssetManager

@{
    AssetManager.RegisterStyle("/css/views/Home/components/StopSidebar/stop-sidebar.css");
    AssetManager.RegisterScript("/lib/jquery-validation/dist/jquery.validate.min.js");
    AssetManager.RegisterScript("/js/views/Home/components/StopSidebar/stopSidebarApi.js");
    AssetManager.RegisterScript("/js/views/Home/components/StopSidebar/stopSidebarValidator.js");
    AssetManager.RegisterScript("/js/views/Home/components/StopSidebar/stopSidebar.js");
}

<aside class="sidebar">
    <div class="sidebar-header">
        <h3 class="sidebar-title">Зупинки</h3>
        <button class="btn-primary" id="open-modal-btn">Додати зупинку</button>
    </div>
    <div class="stop-list">
        @foreach (var stop in Model.Stops)
        {
            <div class="stop-item" data-id="@stop.Id"
                 data-lat="@stop.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                 data-lon="@stop.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)">

                <span class="stop-marker">📍</span>

                <div class="stop-name"><b>@stop.Name</b></div>

                @if (Model.User != null && (stop.CreatedById == Model.User.Id || Model.User.Roles.Contains(AppRole.Admin) || Model.User.Roles.Contains(AppRole.Moderator)))
                {
                    <div class="editing-container">
                        <input type="text" class="edit-input" value="@stop.Name" autocomplete="off" />
                    </div>

                    <div class="stop-actions view-actions">
                        <button class="icon-btn btn-edit-stop" title="Редагувати"><img src="~/images/icons/edit.svg" alt="EditIcon" /></button>
                        <button class="icon-btn btn-delete-stop" title="Видалити"><img src="~/images/icons/delete.svg" alt="CloseIcon" /></button>
                    </div>

                    <div class="stop-actions edit-actions">
                        <button class="icon-btn btn-edit-accept" title="Зберегти"><img src="~/images/icons/accept.svg" alt="AcceptIcon" /></button>
                        <button class="icon-btn btn-edit-close" title="Скасувати"><img src="~/images/icons/close.svg" alt="CloseIcon" /></button>
                    </div>
                }
            </div>
        }
    </div>

    <template id="tpl-add-stop">
        <form id="form-add-stop" class="modal-form-layout">
            <div class="form-group">
                <label class="form-label">Назва зупинки</label>
                <input type="text" name="name" id="stop-name" required placeholder="Центральний вокзал" class="form-input" />
            </div>

            <div class="form-group">
                <label class="form-label">Тип</label>
                <select name="type" id="stop-type" class="form-input">
                    <option value="bus">Автобус</option>
                    <option value="tram">Трамвай</option>
                    <option value="trolleybus">Тролейбус</option>
                    <option value="combined">Комбінована</option>
                </select>
            </div>

            <div class="form-group relative-container">
                <label class="form-label">Пошук місця</label>
                <div class="flex-search-group">
                    <input type="text" id="address-search" placeholder="Почніть вводити назву місця..." class="form-input flex-1" autocomplete="off" />
                    <button type="button" id="btn-search-trigger" class="btn-search-icon">
                        <span class="search-icon">🔍</span>
                        <span class="spinner-icon hidden">🔄</span>
                    </button>
                </div>
                <div id="search-suggestions" class="suggestions-dropdown hidden"></div>
            </div>

            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label">Широта</label>
                    <input type="number" step="any" name="latitude" id="stop-lat" required placeholder="50.4501" class="form-input" />
                </div>
                <div class="form-group">
                    <label class="form-label">Довгота</label>
                    <input type="number" step="any" name="longitude" id="stop-lon" required placeholder="30.5234" class="form-input" />
                </div>
            </div>

            <button type="button" id="btn-pick-on-map" class="btn-outline-map">
                📍 Обрати на карті
            </button>

            <div class="modal-footer">
                <button type="button" class="btn-primary" id="js-close-modal">
                    <span class="btn-text">Скасувати</span>
                </button>
                <button type="submit" id="btn-submit-stop" class="btn-primary">
                    <span class="btn-text">Створити зупинку</span>
                    <span class="spinner"></span>
                </button>
            </div>
        </form>
    </template>
</aside>